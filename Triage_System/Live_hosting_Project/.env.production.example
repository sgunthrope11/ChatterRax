# Production environment variables example
# Add these through your hosting provider's environment/secret settings.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

GEMINI_ENABLED=True
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=30

BOT_DOMAIN=microsoft365
# BOT_DOMAINS=microsoft365,test

FLASK_DEBUG=False
CHAT_STATE_TTL_SECONDS=21600
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD

TICKET_EMAIL_ENABLED=False
TICKET_EMAIL_TO=admin1@example.com,admin2@example.com
APP_PUBLIC_URL=https://your-app.example.com
TICKET_ADMIN_URL=https://your-app.example.com/admin
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USERNAME=your_sending_email@example.com
SMTP_PASSWORD=YOUR_SMTP_OR_APP_PASSWORD
SMTP_FROM=your_sending_email@example.com
