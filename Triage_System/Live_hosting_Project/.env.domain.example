# Safe domain-only variables
# This file contains no API keys, database URLs, or email credentials.
# For local development, copy this to .env.domain and edit the domain values.

# Use one domain pack.
BOT_DOMAIN=microsoft365

# Or use multiple domain packs together.
# If BOT_DOMAINS is set, it takes priority over BOT_DOMAIN.
# BOT_DOMAINS=microsoft365,test

# Optional advanced override for a custom domain JSON file.
# BOT_DOMAIN_PATH=C:\path\to\domain.json
