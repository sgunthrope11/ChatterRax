# Railway Variables example
# Add these in Railway: Project > Service > Variables.
# Railway does not automatically read this file during deploy; use it as the copy/import source.

# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Domain/demo configuration
GEMINI_ENABLED=True
BOT_DOMAIN=microsoft365
FLASK_DEBUG=False

# Optional Gemini tuning
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=30
CHAT_STATE_TTL_SECONDS=21600

# Ticket email alerts through Gmail SMTP
TICKET_EMAIL_ENABLED=True
TICKET_EMAIL_TO=admin-alerts@gmail.com
TICKET_ADMIN_URL=https://your-railway-app.up.railway.app/admin
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USERNAME=yourgmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=yourgmail@gmail.com
