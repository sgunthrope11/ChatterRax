# Required on Railway
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Production defaults
GEMINI_ENABLED=True
FLASK_DEBUG=False

# Domain selection is split into .env.domain locally.
# Railway users can set BOT_DOMAIN or BOT_DOMAINS directly in Railway Variables.

# Optional overrides
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_TIMEOUT_SECONDS=30
# CHAT_STATE_TTL_SECONDS=21600

# Optional ticket email alerts
TICKET_EMAIL_ENABLED=False
TICKET_EMAIL_TO=admin-alerts@gmail.com
TICKET_ADMIN_URL=https://your-railway-app.up.railway.app/admin
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USERNAME=yourgmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=yourgmail@gmail.com
